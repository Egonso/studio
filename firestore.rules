rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Simplified Org Access: In real app, check user claims or 'users' collection
    function canAccessOrg(orgId) {
       return isSignedIn(); // Placeholder for now - allows authenticated users
    }

    // --- OLD / COMPATIBILITY RULES ---
    match /projects/{projectId} {
      allow read, write: if isSignedIn();
    }
    match /users/{userId} {
      allow read, write: if request.auth.uid == userId;
    }

    // --- NEW ARCHITECTURE RULES ---

    // 1. Workspace Projects (Containers)
    match /workspaceProjects/{projectId} {
      allow read, write: if isSignedIn() && canAccessOrg(resource.data.orgId);
    }
    
    // 2. AI Systems (Core Object)
    match /aiSystems/{systemId} {
      allow read, write: if isSignedIn() && canAccessOrg(resource.data.orgId);
      
      // Subcollection: Assessments
      match /assessments/{assessmentId} {
        allow read, write: if isSignedIn();
      }
    }
    
    // 3. ISO AIMS (Org Singleton)
    match /isoAIMS/{aimsId} {
      allow read, write: if isSignedIn() && canAccessOrg(resource.data.orgId);
    }
  }
}
