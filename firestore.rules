
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Customers collection: Only the webhook function should write here.
    // The client needs to read it to check for registration eligibility.
    match /customers/{email} {
      allow read: if request.auth != null; // Allow logged-in users to check
      allow write: if false; // No client-side writes
    }
    
    // Stripe events: Only backend/webhook can write. No client access needed.
    match /stripe_events/{eventId} {
        allow read, write: if false;
    }
    
    // User-specific data
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
