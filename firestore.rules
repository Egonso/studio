rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read and write their own data.
    // This covers projects, assessments, contexts, etc.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Rules for the sharedPolicies collection
    match /sharedPolicies/{policyId} {
      // Allow any authenticated user to create a new shared policy,
      // as long as they are the author.
      allow create: if request.auth != null && request.auth.uid == request.resource.data.authorId;

      // Allow anyone (even unauthenticated users) to read a specific policy
      // This is necessary for the shared link to work.
      allow get: if true;

      // Disallow listing, updating, or deleting for everyone to keep them secure.
      allow list, update, delete: if false;
    }

    // A fallback rule to deny all other access to the database for security.
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
