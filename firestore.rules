rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow reading customer status for registration check, but only the status field.
    match /customers/{email} {
      allow get: if true;
      allow list, write, update, delete: if request.auth != null;
    }
    
    // Secure user-specific data
    match /users/{userId}/{document=**} {
      allow read, write, update, delete: if request.auth != null && request.auth.uid == userId;
    }

    // Stripe events can only be written from the backend (Cloud Function).
    match /stripe_events/{eventId} {
      allow read, write: if false;
    }
  }
}
