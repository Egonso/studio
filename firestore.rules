
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Customers collection:
    // - Only logged-in users who are also paying customers can create/update their own document.
    // - Reading is disallowed for clients to protect customer data. Server-side access only.
    match /customers/{email} {
      allow read: if false; // No client-side reads
      allow create, update: if request.auth != null && request.auth.token.email.lower() == email.lower() && exists(/databases/$(database)/documents/customers/$(request.auth.token.email.lower()));
    }

    // Stripe events log:
    // - Completely locked down. Only accessible from server-side (e.g., Cloud Functions).
    match /stripe_events/{eventId} {
      allow read, write: if false;
    }

    // User-specific data (projects, course progress, etc.)
    // - Users can only read and write their own data.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
