rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    // Simplified Org Access: In real app, check user claims or 'users' collection
    function canAccessOrg(orgId) {
       return isSignedIn(); // Placeholder - allows authenticated users
    }

    // --- LEGACY DATA ---
    // Allow access to user-specific project lists (Missing in previous version!)
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      
      match /projects/{projectId} {
        allow read, write: if isOwner(userId);
        
        // Allow access to subcollections of projects (legacy portfolio, etc.)
        match /{document=**} {
            allow read, write: if isOwner(userId);
        }
      }
      
      match /appData/{docId} {
        allow read, write: if isOwner(userId);
      }

      // Standalone Registers (User-Scoped)
      match /registers/{registerId} {
        allow read, write: if isOwner(userId);

        match /useCases/{useCaseId} {
          allow read, write: if isOwner(userId);
        }
      }
    }

    // Register Access Codes (Hybrid Auth – employees capture without login)
    // Client cannot read lists. Only validate server-side via API or if owner.
    match /registerAccessCodes/{code} {
      allow read: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid;
      allow update: if isSignedIn()
        && resource.data.ownerId == request.auth.uid;
      allow delete: if isSignedIn()
        && resource.data.ownerId == request.auth.uid;
    }

    // Public Use-Case Index (Verify Lookup)
    // Anyone can read (public verify). Only the owner can write.
    match /publicUseCases/{hashId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid;
      allow update: if isSignedIn()
        && resource.data.ownerId == request.auth.uid;
      allow delete: if isSignedIn()
        && resource.data.ownerId == request.auth.uid;
    }

    // --- NEW ARCHITECTURE ---

    // 1. Workspace Projects (Containers)
    match /workspaceProjects/{projectId} {
      allow read, write: if isSignedIn() && canAccessOrg(resource.data.orgId);
    }
    
    // 2. AI Systems (Core Object)
    // Note: List queries MUST filter by 'orgId' for this rule to work strictly on lists.
    match /aiSystems/{systemId} {
      allow read, write: if isSignedIn() && canAccessOrg(resource.data.orgId);
      
      // Subcollection: Assessments
      match /assessments/{assessmentId} {
        allow read, write: if isSignedIn();
      }
    }
    
    // 3. ISO AIMS (Org Singleton)
    match /isoAIMS/{aimsId} {
      allow read, write: if isSignedIn() && canAccessOrg(resource.data.orgId);
    }
    
    // 4. Shared Policies (Used in CBS)
    match /sharedPolicies/{policyId} {
        allow read: if true; // Public read for sharing
        allow create: if isSignedIn();
    }
    
    // --- STRIPE & USER DATA (Option C Architecture) ---
    
    // 5. Customers Collection - Created by Stripe Webhook (Admin SDK only writes)
    // Users can only read their own customer record
    match /customers/{email} {
      allow read: if isSignedIn() && request.auth.token.email.lower() == email.lower();
      allow write: if false; // Only Admin SDK (webhook) can write
    }
    
    // 6. User Exams - Synced from Landing Page (Admin SDK only writes)
    // Users can only read their own exam results
    match /user_exams/{email} {
      allow read: if isSignedIn() && request.auth.token.email.lower() == email.lower();
      allow write: if false; // Only Admin SDK (API) can write
    }
    
    // 7. User Certificates - Synced from Landing Page (Admin SDK only writes)
    // Users can only read their own certificate data
    match /user_certificates/{email} {
      allow read: if isSignedIn() && request.auth.token.email.lower() == email.lower();
      allow write: if false; // Only Admin SDK (API) can write
    }
    
    // 8. Public Certificates - Safe subset for Trust Portal
    // Anyone can read if they have the code (docId)
    match /public_certificates/{code} {
      allow read: if true;
      allow write: if false; // Only Admin SDK (API) can write
    }

    // 9. Stripe Events Log - Admin only, no client access
    match /stripe_events/{eventId} {
      allow read, write: if false; // Only Admin SDK
    }

    // 10. Public Trust Portals
    match /publicTrustPortals/{projectId} {
      allow read: if true;
      // Allow any authenticated user to write - ownerId is set by the application
      allow write: if isSignedIn();
      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    // 11. Project Tools (New Architecture Single Source of Truth)
    match /projects/{projectId} {
      // Allow if user is owner of the project (checking legacy path or new workspace path)
      // For now, loose check for authenticated users, can be tightened later.
      allow read, write: if isSignedIn(); 
      
      match /tools/{toolId} {
        allow read, write: if isSignedIn();
      }
    }
  }
}
