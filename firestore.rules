rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // User-specific data rules: Allow users to read/write their own data.
    // This is essential for projects, assessments, and other user-specific features.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Rules for the new sharedPolicies collection
    match /sharedPolicies/{policyId} {
      // Allow anyone to read a specific policy if they have the link
      allow get: if true;

      // Allow authenticated users to create a new policy
      // - They must be logged in.
      // - The authorId in the new document must match their own user ID.
      allow create: if request.auth != null && request.resource.data.authorId == request.auth.uid;

      // Do not allow listing all policies or updating/deleting them for now
      allow list, update, delete: if false;
    }

    // Fallback for any other collections - deny all access by default.
    // This rule was missing and is important for security.
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
