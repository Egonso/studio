
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Spezifische Sammlungen zuerst ---

    // Benutzer können nur ihre eigenen Unterdokumente lesen und schreiben.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Geteilte Richtlinien:
    // - Jeder kann eine einzelne Richtlinie lesen (wenn er den Link hat).
    // - Niemand kann die gesamte Liste der Richtlinien abrufen.
    // - Nur authentifizierte Benutzer können eine neue Richtlinie erstellen, und sie müssen der Autor sein.
    match /sharedPolicies/{policyId} {
      allow get: if true;
      allow list: if false;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.authorId;
    }

    // --- Allgemeine Fallback-Regel ZULETZT ---
    // Diese Regel fängt alle Pfade ab, die nicht oben explizit definiert wurden,
    // und verweigert den Zugriff. Sie darf keine anderen `match`-Blöcke umschließen.
    match /{path=**} {
        allow read, write: if false;
    }
  }
}
