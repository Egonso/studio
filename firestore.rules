rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read/write their own data. This is crucial for registration,
    // login, and all project-related data storage.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Rules for the new shared policies feature.
    // Allow authenticated users to create policies if they are the author.
    // Allow anyone with the link to read a single policy.
    match /sharedPolicies/{policyId} {
      allow create: if request.auth != null && request.auth.uid == request.resource.data.authorId;
      allow get: if true;
      // Explicitly deny listing all policies for privacy, and deny updates/deletes.
      allow list, update, delete: if false;
    }

    // Security Fallback Rule: This is intentionally placed last.
    // It denies any read or write access to any other path not explicitly matched above.
    match /{path=**} {
        allow read, write: if false;
    }
  }
}
