
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user owns the data
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Allow unauthenticated reads on the 'customers' collection for registration check
    match /customers/{email} {
      allow get: if true;
      allow list, create, update, delete: if false; // Disallow all other operations
    }
    
    // Secure all user-specific data under a 'users' collection
    match /users/{userId}/{document=**} {
      allow read, write: if isAuthenticated() && isOwner(userId);
    }
    
    // Disallow any other access to prevent data leaks.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
