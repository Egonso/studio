rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Allow users to read and write their own data
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Rules for shared policies
    match /sharedPolicies/{policyId} {
      // Logged-in users can create a shared policy if they are the author.
      allow create: if request.auth != null && request.auth.uid == request.resource.data.authorId;

      // Anyone can read a specific shared policy if they have the link/ID.
      allow get: if true;

      // Nobody can list all policies, update, or delete them.
      allow list, update, delete: if false;
    }
  }
}
