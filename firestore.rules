
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users can only read and write their own data.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // New rules for shared policies
    match /sharedPolicies/{policyId} {
      // Authenticated users can create a shared policy.
      // The authorId in the document must match their own UID.
      allow create: if request.auth != null && request.auth.uid == request.resource.data.authorId;
      
      // Anyone can read (get) a single shared policy if they have the link/ID.
      allow get: if true;
      
      // No one can list all policies, update or delete them through the client SDK.
      allow list, update, delete: if false;
    }

    // Default deny all other access
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
