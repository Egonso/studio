{
  "manifest_version": 3,
  "name": "KI-Register Quick Capture",
  "description": "Oeffnet die Quick-Capture-Maske des KI-Registers jederzeit aus der Chrome-Toolbar.",
  "version": "0.1.1",
  "permissions": ["tabs", "windows", "contextMenus", "offscreen"],
  "host_permissions": [
    "https://kiregister.com/*",
    "https://www.kiregister.com/*",
    "http://localhost:3000/*",
    "http://127.0.0.1:3000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "KI-Register Quick Capture",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "commands": {
    "open-quick-capture": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Quick Capture im kompakten Fenster oeffnen"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
